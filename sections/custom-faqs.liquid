{% assign meta_title = product.metafields.custom.best_quality_section_title %}
{% assign meta_content = product.metafields.custom.best_quality_section_description %}

<div class="custom_image_text_reverse"
  {% if section.settings.background_image != blank %}
    style="background-image:url({{ section.settings.background_image | image_url: width: 2000 }}); background-size:cover; background-position:center;"
  {% endif %}
>
  <div class="container">

    <div class="custom_imgtext_left_col">
      {% if section.settings.left_img != blank %}
        <img 
          src="{{ section.settings.left_img | image_url: width: 800 }}" 
          alt="Section Image"
          loading="lazy"
        >
      {% endif %}
    </div>

    <div class="custom_img_text_rightcol">

      {% if meta_title != blank %}
        <h2>{{ meta_title }}</h2>
      {% elsif section.settings.head != blank %}
        <h2>{{ section.settings.head }}</h2>
      {% endif %}

      {% if meta_content != blank %}
        <div class="cstm_imgrev_cont">
          {{ meta_content }}
        </div>
      {% elsif section.settings.content != blank %}
        <div class="cstm_imgrev_cont">
          {{ section.settings.content }}
        </div>
      {% endif %}

    </div>

  </div>
</div>

<style>
.custom_image_text_reverse {
  padding: 60px 0;
}

.custom_image_text_reverse .container {
  display: flex;
  align-items: center;
  gap: 40px;
}

.custom_imgtext_left_col {
  width: 50%;
}

.custom_imgtext_left_col img {
  width: 100%;
  height: auto;
  display: block;
}

.custom_img_text_rightcol {
  width: 50%;
}

@media (max-width: 768px) {
  .custom_image_text_reverse .container {
    flex-direction: column;
  }

  .custom_imgtext_left_col,
  .custom_img_text_rightcol {
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Custom Image Text Reverse",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "left_img",
      "label": "Left Column Image"
    },
    {
      "type": "text",
      "id": "head",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Custom Image Text Reverse"
    }
  ]
}
{% endschema %}
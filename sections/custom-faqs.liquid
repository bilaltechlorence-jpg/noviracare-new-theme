<section class="novira-section">
  <div class="novira-container">

    <!-- LEFT CONTENT -->
    <div class="novira-left">
      <h2>{{ section.settings.left_title }}</h2>
      <div class="novira-text">
        {{ section.settings.left_content }}
      </div>
    </div>

    <!-- RIGHT CARD -->
    <div class="novira-right">
      <h3>{{ section.settings.right_title }}</h3>

      <ul class="novira-list">
        {% for block in section.blocks %}
          <li>
            ✓ {{ block.settings.list_item }}
          </li>
        {% endfor %}
      </ul>

      {% if section.settings.right_image %}
        <div class="novira-image">
          <img src="{{ section.settings.right_image | image_url: width: 600 }}" alt="Knee Relief">
        </div>
      {% endif %}

      <p class="novira-bottom-text">
        {{ section.settings.bottom_text }}
      </p>
    </div>

  </div>
</section>

<style>
.novira-section {
  background: #f6a391;
  padding: 60px 20px;
}

.novira-container {
  max-width: 1200px;
  margin: auto;
  display: flex;
  gap: 40px;
  align-items: center;
  flex-wrap: wrap;
}

.novira-left {
  flex: 1;
}

.novira-left h2 {
  font-size: 28px;
  margin-bottom: 20px;
}

.novira-text {
  font-size: 16px;
  line-height: 1.6;
}

.novira-right {
  flex: 1;
  background: #e57373;
  padding: 30px;
  border-radius: 20px;
  color: #fff;
}

.novira-right h3 {
  margin-bottom: 20px;
}

.novira-list {
  list-style: none;
  padding: 0;
  margin-bottom: 20px;
}

.novira-list li {
  margin-bottom: 10px;
}

.novira-image img {
  width: 100%;
  border-radius: 12px;
  margin-bottom: 20px;
}

.novira-bottom-text {
  font-weight: bold;
}
</style>

{% schema %}
{
  "name": "Novira Knee Section",
  "settings": [
    {
      "type": "text",
      "id": "left_title",
      "label": "Left Title",
      "default": "Knee Pain? Get Relief Without Surgery"
    },
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Content",
      "default": "<p>It only takes 10 minutes every day to begin relieving years worth of discomfort.</p>"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Right Box Title",
      "default": "Who Is Novira Relief Pro Massager For?"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "If knee pain is slowing you down, this was made for you."
    }
  ],
  "blocks": [
    {
      "type": "list",
      "name": "List Item",
      "settings": [
        {
          "type": "text",
          "id": "list_item",
          "label": "List Text",
          "default": "Osteoarthritis"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Novira Knee Section"
    }
  ]
}
{% endschema %}
{% if section.settings.heading != blank or section.settings.content != blank %}

<section class="best-quality-section"
  {% if section.settings.bg != blank %}
    style="background-image: url({{ section.settings.bg | image_url }});"
  {% endif %}
>
  <div class="container">
    <div class="best-quality-wrapper">

      <!-- LEFT IMAGE -->
      {% if section.settings.left_img != blank %}
      <div class="best-quality-image">
        <img 
          src="{{ section.settings.left_img | image_url: width: 800 }}" 
          alt="Best Quality Image">
      </div>
      {% endif %}

      <!-- RIGHT CONTENT -->
      <div class="best-quality-content">

        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.content != blank %}
          <div class="best-quality-text">
            {{ section.settings.content }}
          </div>
        {% endif %}

      </div>

    </div>
  </div>
</section>

{% endif %}

<style>
.best-quality-section {
  padding: 80px 20px;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
}

.best-quality-wrapper {
  display: flex;
  align-items: center;
  gap: 60px;
  flex-wrap: wrap;
}

.best-quality-image {
  flex: 1;
}

.best-quality-image img {
  width: 100%;
  border-radius: 16px;
  display: block;
}

.best-quality-content {
  flex: 1;
}

.best-quality-content h2 {
  font-size: 36px;
  margin-bottom: 20px;
}

.best-quality-text {
  font-size: 18px;
  line-height: 1.6;
}

/* Mobile */
@media (max-width: 768px) {
  .best-quality-wrapper {
    flex-direction: column;
  }
}
</style>

{% schema %}
{
  "name": "Best Quality Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "left_img",
      "label": "Left Column Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Best Quality Section"
    }
  ]
}
{% endschema %}
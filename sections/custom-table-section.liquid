{% assign pro_main_title = product.metafields.custom.table_product_title %}
{% assign table_item_first = product.metafields.custom.table_first_item %}
{% assign first_check_mark = product.metafields.custom.table_first_item_check_mark %}
{% assign table_item_second = product.metafields.custom.table_second_item %}
{% assign second_check_mark = product.metafields.custom.table_second_item_check_mark %}
{% assign table_item_third = product.metafields.custom.table_third_item %}
{% assign third_check_mark = product.metafields.custom.table_third_item_check_mark %}
{% assign table_item_fourth = product.metafields.custom.table_fourth_item %}
{% assign fourth_check_mark = product.metafields.custom.table_fourth_item_check_mark %}
{% assign table_item_fifth = product.metafields.custom.table_fifth_item %}
{% assign fifth_check_mark = product.metafields.custom.table_fifth_item_check_mark %}
{% assign check_box_title = product.metafields.custom.check_box_title %}
{% assign check_box_description = product.metafields.custom.check_box_description %}

{% if table_item_first != blank %}

<section class="custom_table_section" style="background-color: {{ section.settings.bg }};">
  <div class="container">

    <div class="custom_table_section_left">
      <h2>{{ check_box_title }}</h2>
      {{ check_box_description }}
    </div>

    <div class="custom_table_section_right">
      <table>
        <tr>
          <th></th>
          <th>{{ pro_main_title }}</th>
          <th>Others</th>
        </tr>

        {% assign items = table_item_first | append: '|' | append: table_item_second | append: '|' | append: table_item_third | append: '|' | append: table_item_fourth | append: '|' | append: table_item_fifth | split: '|' %}

        {% assign checks = first_check_mark | append: '|' | append: second_check_mark | append: '|' | append: third_check_mark | append: '|' | append: fourth_check_mark | append: '|' | append: fifth_check_mark | split: '|' %}

        {% for item in items %}
          {% if item != blank %}
          <tr>
            <td>{{ item }}</td>

            <td>
              {% if checks[forloop.index0] == 'true' %}
                <span class="green">✔</span>
              {% else %}
                <span class="red">✖</span>
              {% endif %}
            </td>

            <td>
              {% if checks[forloop.index0] == 'true' %}
                <span class="red">✖</span>
              {% else %}
                <span class="green">✔</span>
              {% endif %}
            </td>
          </tr>
          {% endif %}
        {% endfor %}

      </table>
    </div>

  </div>
</section>

{% endif %}

<!-- NOVIRA INFO SECTION -->

<section class="novira-section">
  <div class="novira-container">

    <div class="novira-left">
      <h2>{{ section.settings.left_title }}</h2>
      <div class="novira-text">
        {{ section.settings.left_content }}
      </div>
    </div>

    <div class="novira-right">
      <h3>{{ section.settings.right_title }}</h3>

      <ul class="novira-list">
        {% for block in section.blocks %}
          <li>✔ {{ block.settings.list_item }}</li>
        {% endfor %}
      </ul>

      {% if section.settings.right_image %}
        <div class="novira-image">
          <img src="{{ section.settings.right_image | image_url: width: 600 }}" alt="">
        </div>
      {% endif %}

      <p class="novira-bottom-text">
        {{ section.settings.bottom_text }}
      </p>
    </div>

  </div>
</section>

<style>
.custom_table_section {
  padding: 60px 20px;
}
.container {
  max-width: 1200px;
  margin: auto;
  display: flex;
  gap: 40px;
  flex-wrap: wrap;
}
.custom_table_section_left,
.custom_table_section_right {
  flex: 1;
}
table {
  width: 100%;
  border-collapse: collapse;
}
th, td {
  padding: 12px;
  border-bottom: 1px solid #ddd;
  text-align: center;
}
.green { color: #4bb82c; font-size: 22px; }
.red { color: #da6262; font-size: 22px; }

.novira-section {
  background: #f6a391;
  padding: 60px 20px;
}
.novira-container {
  max-width: 1200px;
  margin: auto;
  display: flex;
  gap: 40px;
  flex-wrap: wrap;
}
.novira-left,
.novira-right {
  flex: 1;
}
.novira-right {
  background: #e57373;
  padding: 30px;
  border-radius: 20px;
  color: #fff;
}
.novira-list {
  list-style: none;
  padding: 0;
}
.novira-list li {
  margin-bottom: 10px;
}
.novira-image img {
  width: 100%;
  border-radius: 12px;
  margin: 20px 0;
}
.novira-bottom-text {
  font-weight: bold;
}
</style>

{% schema %}
{
  "name": "Comparison Section",
  "settings": [
    {
      "type": "color",
      "id": "bg",
      "label": "Table Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "left_title",
      "label": "Left Title",
      "default": "Knee Pain? Get Relief Without Surgery"
    },
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left Content",
      "default": "<p>It only takes 10 minutes every day to begin relieving years worth of discomfort.</p>"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Right Box Title",
      "default": "Who Is Novira Relief Pro Massager For?"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "If knee pain is slowing you down, this was made for you."
    }
  ],
  "blocks": [
    {
      "type": "list",
      "name": "List Item",
      "settings": [
        {
          "type": "text",
          "id": "list_item",
          "label": "List Text",
          "default": "Osteoarthritis"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Comparison Section"
    }
  ]
}
{% endschema %}